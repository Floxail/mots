    {
      "id": "readme_game_concept",
      "label": "Mots.js Multiplayer Crossword Game",
      "file_type": "concept",
      "source_file": "README.md",
      "source_location": "1-9",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "A Node.js-based multiplayer crossword (mots fléchés) game supporting up to 9 players, with grids fetched from the GSO provider at rcijeux.fr. Designed for desktop play, real-time via Socket.IO."
    },
