      "id": "readme_bonus_system",
      "label": "Bonus Points System",
      "file_type": "concept",
      "source_file": "README.md",
      "source_location": "46-55",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Four bonus types: Preum's (+4, first word), Finish him (+4, last word), Débloqueur (+5, first word after 2min inactivity), Gros mot (+3, word ≥6 letters). Adds competitive incentive beyond raw letter count."
    },
