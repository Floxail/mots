doctype html
html
  head
    script(type='text/javascript', src=wsAddress + '/socket.io/socket.io.js').

    <link href="/images/favicon.ico" rel="icon" type="image/ico" />
    <meta charset='utf-8'>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Mots.js</title>

    <link href="stylesheets/mfl.css" media="screen" rel="stylesheet" type="text/css" />

    <script data-main="javascripts/game/mflEngine" src="javascripts/lib/require.min.js"></script>

  body.

    <!-- Lobby panel — shown first, lets players create/join a room or go solo -->
    <div id="lobby-panel" class='ui ui-displayed'>
      <header>
        <div class="lp-case lp-title">M</div><div class="lp-case lp-title">O</div><div class="lp-case lp-title">T</div><div class="lp-case lp-title">S</div><div class="lp-case lp-title">.</div><div class="lp-case lp-title">J</div><div class="lp-case lp-title">S</div>
      </header>

      <section id="lobby-section">

        <div id="lobby-rooms">
          <div id="lobby-room-list"><em class="lobby-connecting">Connexion au serveur...</em></div>
        </div>

        <div id="lobby-actions">
          <div class="lobby-group">
            <input type="number" id="lobby-grid-input" placeholder="N° de grille (vide = du jour)" min="1">
            <input type="button" id="lobby-create-btn" value="Créer une salle">
          </div>

          <p class="lobby-sep">— ou rejoindre —</p>

          <div class="lobby-group">
            <input type="text" id="lobby-code-input" placeholder="Code de salle (ex: AB3C)" maxlength="4" autocomplete="off" autocorrect="off" autocapitalize="characters">
            <input type="button" id="lobby-join-btn" value="Rejoindre">
          </div>

          <p class="lobby-sep">— ou —</p>

          <input type="button" id="lobby-solo-btn" value="Jouer en solo">
        </div>

      </section>
    </div>


    <!-- Login page -->
    <div id="login-panel" class='ui'>
      <header>
        <div class="lp-case lp-title">M</div><div class="lp-case lp-title">O</div><div class="lp-case lp-title">T</div><div class="lp-case lp-title">S</div><div class="lp-case lp-title">.</div><div class="lp-case lp-title">J</div><div class="lp-case lp-title">S</div>
      </header>

      <section id="lp-infos">
        <input type="text" id="lp-nick" value="" placeholder="Votre pseudo" autocomplete="off">

        <div id="lp-logos"></div>

        <input type="button" id="lp-start-btn" value="Jouer !">
      </section>

    </div>


    <!-- Game screen -->
    <div id="game-panel" class='ui'>

      <section id="gs-chat">
        <div id="gsc-messages"></div>
        <textarea id="gsc-write" placeholder="Votre message" tabIndex="-1"></textarea>
        <div id="gsc-command-start" class="gsc-button">Lancer</div>
        <div id="gsc-command-grid" class="gsc-button">Grille</div>
      </section>

      <section id="gs-grid-container"></section>

      <section id="gs-scores"></section>

    </div>

    <!-- Error screen -->
    <div id="error-panel" class='ui'>
      <h1 id="ep-title">Ooooops !</h1>
      <strong id="ep-text">Something goes wrong</strong>
    </div>

    <div id="info-tooltip"></div>
